{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AllTokens 文档",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "server": "https://alltoken.aatest.online",
      "auth": {
        "method": "bearer"
      }
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required"
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "开始使用",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "cn/index",
                  "cn/quickstart"
                ]
              }
            ]
          },
          {
            "tab": "接口参考",
            "groups": [
              {
                "group": "接口文档",
                "pages": [
                  "cn/api-reference/introduction"
                ]
              },
              {
                "group": "接口示例",
                "pages": [
                  "cn/api-reference/chat-completions",
                  "cn/api-reference/responses",
                  "cn/api-reference/responses-compact",
                  "cn/api-reference/messages",
                  "cn/api-reference/models",
                  "cn/api-reference/embeddings",
                  "cn/api-reference/rerank",
                  "cn/api-reference/images-generations",
                  "cn/api-reference/images-edits",
                  "cn/api-reference/images-variations",
                  "cn/api-reference/audio-speech",
                  "cn/api-reference/audio-transcriptions",
                  "cn/api-reference/audio-translations"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "en/index",
                  "en/quickstart"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "en/api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "en/api-reference/chat-completions",
                  "en/api-reference/responses",
                  "en/api-reference/responses-compact",
                  "en/api-reference/messages",
                  "en/api-reference/models",
                  "en/api-reference/embeddings",
                  "en/api-reference/rerank",
                  "en/api-reference/images-generations",
                  "en/api-reference/images-edits",
                  "en/api-reference/images-variations",
                  "en/api-reference/audio-speech",
                  "en/api-reference/audio-transcriptions",
                  "en/api-reference/audio-translations"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh-Hant",
        "tabs": [
          {
            "tab": "開始使用",
            "groups": [
              {
                "group": "開始使用",
                "pages": [
                  "zh-Hant/index",
                  "zh-Hant/quickstart"
                ]
              }
            ]
          },
          {
            "tab": "API 參考",
            "groups": [
              {
                "group": "API 文件",
                "pages": [
                  "zh-Hant/api-reference/introduction"
                ]
              },
              {
                "group": "端點範例",
                "pages": [
                  "zh-Hant/api-reference/chat-completions",
                  "zh-Hant/api-reference/responses",
                  "zh-Hant/api-reference/responses-compact",
                  "zh-Hant/api-reference/messages",
